---
import Layout from "@/layouts/main.astro"
import { FactionSpectrum } from "@/components/FactionSpectrum"
import { ThemeToggle } from "@/components/ThemeToggle"
import { getPeople } from "@/lib/content"

const people = getPeople().sort((a, b) => a.name_en.localeCompare(b.name_en))

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "People",
  description: "People in the OIFI Databook",
  numberOfItems: people.length,
  itemListElement: people.map((p, i) => ({
    "@type": "ListItem",
    position: i + 1,
    url: `https://databook.oifi.org/people/${p.slug}`,
    name: p.name_en,
  })),
}
---

<Layout title="People" description="People in the OIFI Databook" canonicalPath="/people" jsonLd={jsonLd}>
  <div class="mx-auto max-w-2xl">
  <h1 class="mb-6 text-2xl font-bold">People</h1>
  <ul class="space-y-3">
    {people.map((p) => (
      <li>
        <a href={`/people/${p.slug}`} class="group flex items-center gap-3">
          <div class="flex flex-col">
            <span class="font-medium group-hover:underline">{p.name_en}</span>
            <span class="text-sm text-muted-foreground">{p.role}</span>
          </div>
          <span class="ml-auto"><FactionSpectrum faction={p.faction} client:load /></span>
        </a>
      </li>
    ))}
  </ul>
  </div>
  <ThemeToggle client:load slot="header-actions" />
</Layout>
