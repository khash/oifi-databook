---
import EntityLayout from "@/layouts/entity.astro"
import { Badge } from "@/components/ui/badge"
import { Separator } from "@/components/ui/separator"
import { getPeople, getConnectionsForEntity, getEntityById, getEntityTypeById } from "@/lib/content"
import { GraphExplorer } from "@/components/GraphExplorer"
import { FactionSpectrum } from "@/components/FactionSpectrum"
import { ConfidenceBadge } from "@/components/ConfidenceBadge"
import { SPECTRUM_FACTIONS, INVERSE_LABELS } from "@/lib/constants"
import { renderMarkdown, stripMarkdown } from "@/lib/markdown"
import type { Person } from "@/lib/types"

export function getStaticPaths() {
  return getPeople().map((p) => ({ params: { slug: p.slug }, props: { person: p } }))
}

const { person } = Astro.props as { person: Person }
const connections = getConnectionsForEntity(person.entity_id)
const desc = stripMarkdown(person.bio).slice(0, 160)

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: person.name_en,
  alternateName: person.has_native_fa_name ? person.name_fa : undefined,
  jobTitle: person.role,
  description: stripMarkdown(person.bio),
  birthDate: person.born ? String(person.born) : undefined,
}
---

<EntityLayout
  title={person.name_en}
  description={desc}
  ogType="profile"
  canonicalPath={`/people/${person.slug}`}
  jsonLd={jsonLd}
  breadcrumb={{ label: "People", href: "/people" }}
>
  <article data-pagefind-body>
    <div class="flex flex-wrap items-baseline gap-3">
      <h1 class="text-2xl font-bold" data-pagefind-meta="title">{person.name_en}</h1>
      {person.has_native_fa_name && <span class="text-lg text-muted-foreground" dir="rtl" lang="fa">{person.name_fa}</span>}
    </div>

    <p class="mt-1 text-sm text-muted-foreground">{person.role}</p>

    <div class="mt-2 flex flex-wrap items-center gap-2">
      {(SPECTRUM_FACTIONS as readonly string[]).includes(person.faction)
        ? <FactionSpectrum faction={person.faction} />
        : <Badge variant="secondary">{person.faction.replace(/-/g, " ")}</Badge>
      }
      {person.tags.map((tag) => (
        <Badge variant="outline">{tag.replace(/-/g, " ")}</Badge>
      ))}
    </div>

    <Separator className="my-6" />

    <div class="prose prose-sm max-w-none" set:html={renderMarkdown(person.bio)} />

    <span data-pagefind-meta={`type:person`} class="hidden" />
    <span data-pagefind-meta={`faction:${person.faction}`} class="hidden" />
    <span data-pagefind-meta={`role:${person.role}`} class="hidden" />
  </article>

  <Fragment slot="sidebar">
    {person.expertise.length > 0 && (
      <div>
        <h2 class="mb-2 text-sm font-medium text-muted-foreground">Expertise</h2>
        <div class="flex flex-wrap gap-1.5">
          {person.expertise.map((tag) => (
            <Badge variant="outline">{tag.replace(/-/g, " ")}</Badge>
          ))}
        </div>
      </div>
    )}

    {connections.length > 0 && (
      <div>
        <h2 class="mb-3 text-sm font-medium text-muted-foreground">Connections</h2>
        <ul class="space-y-2">
          {connections.map((conn) => {
            const otherId = conn.from_entity === person.entity_id ? conn.to_entity : conn.from_entity
            const other = getEntityById(otherId)
            if (!other) return null
            const entityType = getEntityTypeById(otherId)
            const href = entityType === "person"
              ? `/people/${other.slug}`
              : entityType === "org"
                ? `/orgs/${other.slug}`
                : `/events/${other.slug}`
            const label = conn.from_entity === person.entity_id
              ? conn.type.replace(/-/g, " ")
              : INVERSE_LABELS[conn.type] ?? conn.type.replace(/-/g, " ")
            return (
              <li>
                <a href={href} class="text-sm font-medium hover:underline">{"name_en" in other ? other.name_en : other.name}</a>
                <div class="flex items-center gap-1 text-xs text-muted-foreground">
                  <span>{label}</span>
                  <ConfidenceBadge client:load confidence={conn.confidence} />
                </div>
              </li>
            )
          })}
        </ul>
      </div>
    )}
  </Fragment>

  <div slot="bottom">
    <h2 class="mb-3 text-sm font-medium text-muted-foreground">Network Graph</h2>
    <div class="h-[500px]">
      <GraphExplorer client:load initialEntityId={person.entity_id} />
    </div>
  </div>
</EntityLayout>
