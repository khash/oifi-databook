---
import "@/styles/global.css"
import { ClientRouter } from "astro:transitions"
import { EntityHoverCardEnhancer } from "@/components/EntityHoverCardEnhancer"

interface Props {
  title?: string
  description?: string
  ogType?: string
  canonicalPath?: string
  jsonLd?: object | object[]
}

const {
  title = "OIFI Databook",
  description = "Iranian political actors, organizations and events",
  ogType = "website",
  canonicalPath,
  jsonLd,
} = Astro.props

const siteUrl = "https://databook.oifi.org"
const canonicalUrl = canonicalPath ? `${siteUrl}${canonicalPath}` : siteUrl
const fullTitle = title === "OIFI Databook" ? title : `${title} | OIFI Databook`
---

<html lang="en">
  <head>
    <ClientRouter />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="OIFI" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      if (localStorage.getItem("theme") === "dark" || (!localStorage.getItem("theme") && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
        document.documentElement.classList.add("dark")
      }
    </script>
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="OIFI Databook" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={`${siteUrl}/og-image.png`} />
    <meta property="og:image:width" content="2816" />
    <meta property="og:image:height" content="1536" />
    <meta property="og:image:alt" content="OIFI Databook" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.png`} />
    {jsonLd && Array.isArray(jsonLd) ? (
      jsonLd.map((ld) => (
        <script type="application/ld+json" set:html={JSON.stringify(ld)} />
      ))
    ) : jsonLd ? (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    ) : null}
    <script is:inline>
      (async () => {
        try {
          const pf = await import("/pagefind/pagefind.js");
          await pf.init();
          window.__pagefind = pf;
        } catch {}
      })();
    </script>
  </head>
  <body class="flex flex-col min-h-screen">
    <header class="border-b border-border">
      <div class="mx-auto flex h-12 max-w-7xl items-center gap-6 px-4 sm:px-6 lg:px-8">
        <a href="https://oifi.org" class="flex items-center gap-1.5 text-sm font-semibold tracking-tight text-muted-foreground hover:text-foreground transition-colors">
          <img src="/oifi-icon.png" alt="OIFI" class="h-5 w-5 opacity-60 dark:invert" />
          OIFI
        </a>
        <span class="text-muted-foreground/40 text-sm">/</span>
        <a href="/" class="text-sm font-semibold tracking-tight">Databook</a>
        <nav class="flex gap-4 text-sm text-muted-foreground">
          <a href="/people" class="hover:text-foreground">People</a>
          <a href="/orgs" class="hover:text-foreground">Orgs</a>
          <a href="/events" class="hover:text-foreground">Events</a>
        </nav>
        <div class="ml-auto">
          <slot name="header-actions" />
        </div>
      </div>
    </header>
    <main class="mx-auto w-full max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <slot />
    </main>
    <EntityHoverCardEnhancer client:load />
    <footer class="border-t border-border mt-auto">
      <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-muted-foreground">
        <a href="https://oifi.org" class="flex items-center gap-1.5 hover:text-foreground transition-colors">
          <img src="/oifi-icon.png" alt="OIFI" class="h-4 w-4 dark:invert" />
          <span>Open Information For Iran</span>
        </a>
        <p>© {new Date().getFullYear()} OIFI. Research tool — not a legal record.</p>
        <nav class="flex gap-4">
          <a href="/people" class="hover:text-foreground">People</a>
          <a href="/orgs" class="hover:text-foreground">Organizations</a>
          <a href="/events" class="hover:text-foreground">Events</a>
          <a href="https://oifi.org" class="hover:text-foreground">About OIFI</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
