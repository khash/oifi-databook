---
import Layout from "@/layouts/main.astro"
import { Badge } from "@/components/ui/badge"
import { ThemeToggle } from "@/components/ThemeToggle"
import { getEvents } from "@/lib/content"

const events = getEvents().sort((a, b) => b.date.localeCompare(a.date))
---

<Layout title="Events" description="Events in the OIFI Databook" canonicalPath="/events">
  <div class="mx-auto max-w-6xl px-4 py-8">
    <h1 class="mb-6 text-2xl font-bold">Events</h1>
    <ul class="space-y-3">
      {events.map((e) => (
        <li>
          <a href={`/events/${e.slug}`} class="group flex items-center gap-3">
            <span class="font-medium group-hover:underline">{e.name}</span>
            <span class="text-sm text-muted-foreground">{e.date}</span>
            <Badge variant="secondary" className="ml-auto">{e.type.replace(/-/g, " ")}</Badge>
          </a>
        </li>
      ))}
    </ul>
  </div>
  <ThemeToggle client:load slot="header-actions" />
</Layout>
