---
import EntityLayout from "@/layouts/entity.astro"
import { Badge } from "@/components/ui/badge"
import { Separator } from "@/components/ui/separator"
import { getEvents, getConnectionsForEntity, getEntityById, getEntityTypeById } from "@/lib/content"
import { GraphExplorer } from "@/components/GraphExplorer"
import { renderMarkdown, stripMarkdown } from "@/lib/markdown"
import type { Event } from "@/lib/types"
import { ConnectionsList } from "@/components/ConnectionsList"
import FormattedDate from "@/components/FormattedDate.astro"
import { INVERSE_LABELS } from "@/lib/constants"

export function getStaticPaths() {
  return getEvents().map((e) => ({ params: { slug: e.slug }, props: { event: e } }))
}

const { event } = Astro.props as { event: Event }
const connections = getConnectionsForEntity(event.entity_id)
const connectionItems = connections.map((conn) => {
  const otherId = conn.from_entity === event.entity_id ? conn.to_entity : conn.from_entity
  const other = getEntityById(otherId)
  if (!other) return null
  const entityType = getEntityTypeById(otherId)
  const href = entityType === "person" ? `/people/${other.slug}` : entityType === "org" ? `/orgs/${other.slug}` : `/events/${other.slug}`
  const label = conn.from_entity === event.entity_id ? conn.type.replace(/-/g, " ") : INVERSE_LABELS[conn.type] ?? conn.type.replace(/-/g, " ")
  return { type: conn.type, confidence: conn.confidence, label, otherName: "name_en" in other ? other.name_en : other.name, href, dateFrom: conn.date_from, dateTo: conn.date_to }
}).filter(Boolean)
const desc = stripMarkdown(event.description).slice(0, 160)

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Event",
  name: event.name,
  description: stripMarkdown(event.description),
  startDate: event.date,
}
---

<EntityLayout
  title={event.name}
  description={desc}
  ogType="website"
  canonicalPath={`/events/${event.slug}`}
  jsonLd={jsonLd}
  breadcrumb={{ label: "Events", href: "/events" }}
>
  <div data-pagefind-body>
    <h1 class="text-2xl font-bold" data-pagefind-meta="title">{event.name}</h1>
    <p class="mt-1 text-sm text-muted-foreground"><FormattedDate date={event.date} /></p>

    <div class="mt-2 flex flex-wrap items-center gap-2">
      <Badge variant="secondary">{event.type.replace(/-/g, " ")}</Badge>
    </div>

    <div class="mt-2 flex flex-wrap items-center gap-2">
      {event.tags.map((tag) => (
        <Badge variant="outline">{tag.replace(/-/g, " ")}</Badge>
      ))}
    </div>

    <Separator className="my-6" />

    <div class="prose prose-sm dark:prose-invert max-w-none" set:html={renderMarkdown(event.description)} />

    {event.body && (
      <div class="prose prose-sm dark:prose-invert mt-6 max-w-none" set:html={renderMarkdown(event.body)} />
    )}

    <span data-pagefind-meta={`type:event`} class="hidden" />
  </div>

  <div class="mt-8">
    <h2 class="mb-3 text-sm font-medium text-muted-foreground">Network Graph</h2>
    <div class="h-[500px]">
      <GraphExplorer client:load initialEntityId={event.entity_id} />
    </div>
  </div>

  <Fragment slot="sidebar">
    {connectionItems.length > 0 && (
      <ConnectionsList client:load connections={connectionItems} />
    )}

    {event.sources.length > 0 && (
      <div>
        <h2 class="mt-8 mb-3 text-sm font-medium text-muted-foreground">Sources</h2>
        <ul class="space-y-2">
          {event.sources.map((src) => (
            <li class="text-sm">
              <a href={src.url} target="_blank" rel="noopener noreferrer" class="font-medium hover:underline">
                {src.title}
              </a>
              <span class="text-muted-foreground"> &middot; {src.publisher}{src.date && <> &middot; <FormattedDate date={src.date} /></>}</span>
            </li>
          ))}
        </ul>
      </div>
    )}
  </Fragment>

</EntityLayout>
