---
import Layout from "@/layouts/main.astro"
import { ThemeToggle } from "@/components/ThemeToggle"

interface Props {
  title: string
  description: string
  ogType?: string
  canonicalPath: string
  jsonLd?: object
  breadcrumb: { label: string; href: string }
}

const { title, description, ogType, canonicalPath, jsonLd, breadcrumb } = Astro.props
const hasSidebar = Astro.slots.has("sidebar")

const siteUrl = "https://databook.oifi.org"
const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: breadcrumb.label, item: `${siteUrl}${breadcrumb.href}` },
    { "@type": "ListItem", position: 2, name: title, item: `${siteUrl}${canonicalPath}` },
  ],
}

const combinedJsonLd = jsonLd ? [jsonLd, breadcrumbLd] : [breadcrumbLd]
---

<Layout title={title} description={description} ogType={ogType} canonicalPath={canonicalPath} jsonLd={combinedJsonLd}>
  <nav aria-label="breadcrumb" class="mb-4">
    <ol class="flex flex-wrap items-center gap-1.5 text-sm text-muted-foreground">
      <li class="inline-flex items-center gap-1">
        <a href={breadcrumb.href} class="transition-colors hover:text-foreground">{breadcrumb.label}</a>
      </li>
      <li role="presentation" aria-hidden="true" class="[&>svg]:size-3.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </li>
      <li class="inline-flex items-center gap-1">
        <span role="link" aria-disabled="true" aria-current="page" class="font-normal text-foreground">{title}</span>
      </li>
    </ol>
  </nav>

  {hasSidebar ? (
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <slot />
      </div>
      <aside class="overflow-hidden">
        <div class="lg:sticky lg:top-16 space-y-6">
          <slot name="sidebar" />
        </div>
      </aside>
    </div>
  ) : (
    <slot />
  )}

  <ThemeToggle client:load slot="header-actions" />
</Layout>
