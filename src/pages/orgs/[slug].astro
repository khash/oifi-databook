---
import EntityLayout from "@/layouts/entity.astro"
import { Badge } from "@/components/ui/badge"
import { Separator } from "@/components/ui/separator"
import { getOrgs, getOrgById, getConnectionsForEntity, getEntityById, getEntityTypeById } from "@/lib/content"
import { GraphExplorer } from "@/components/GraphExplorer"
import { renderMarkdown, stripMarkdown } from "@/lib/markdown"
import type { Org } from "@/lib/types"
import { INVERSE_LABELS } from "@/lib/constants"
import { FactionSpectrum } from "@/components/FactionSpectrum"
import { ConfidenceBadge } from "@/components/ConfidenceBadge"

export function getStaticPaths() {
  return getOrgs().map((o) => ({ params: { slug: o.slug }, props: { org: o } }))
}

const { org } = Astro.props as { org: Org }
const connections = getConnectionsForEntity(org.entity_id)
const parentOrg = org.parent_org ? getOrgById(org.parent_org) : null
const desc = stripMarkdown(org.description).slice(0, 160)

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: org.name_en,
  alternateName: org.has_native_fa_name ? org.name_fa : undefined,
  description: stripMarkdown(org.description),
  foundingDate: org.founded ? String(org.founded) : undefined,
  dissolutionDate: org.dissolved ? String(org.dissolved) : undefined,
}
---

<EntityLayout
  title={org.name_en}
  description={desc}
  ogType="website"
  canonicalPath={`/orgs/${org.slug}`}
  jsonLd={jsonLd}
  breadcrumb={{ label: "Organisations", href: "/orgs" }}
>
  <article data-pagefind-body>
    <div class="flex flex-wrap items-baseline gap-3">
      <h1 class="text-2xl font-bold" data-pagefind-meta="title">{org.name_en}</h1>
      {org.has_native_fa_name && <span class="text-lg text-muted-foreground" dir="rtl" lang="fa">{org.name_fa}</span>}
    </div>

    <p class="mt-1 text-sm text-muted-foreground">
      {org.type.replace(/-/g, " ")}
      {org.founded && <span> &middot; Founded {org.founded}</span>}
      {org.dissolved && <span> &middot; Dissolved {org.dissolved}</span>}
      {parentOrg && (
        <span>
          {" "}&middot; Part of{" "}
          <a href={`/orgs/${parentOrg.slug}`} class="underline hover:text-foreground">{parentOrg.name_en}</a>
        </span>
      )}
    </p>

    <div class="mt-2 flex flex-wrap items-center gap-2">
      {org.faction && <FactionSpectrum client:load faction={org.faction} />}
      {org.tags.map((tag) => (
        <Badge variant="outline">{tag.replace(/-/g, " ")}</Badge>
      ))}
    </div>

    <Separator className="my-6" />

    <div class="prose prose-sm max-w-none" set:html={renderMarkdown(org.description)} />

    <span data-pagefind-meta={`type:org`} class="hidden" />
    {org.faction && <span data-pagefind-meta={`faction:${org.faction}`} class="hidden" />}
  </article>

  <Fragment slot="sidebar">
    {connections.length > 0 && (
      <div>
        <h2 class="mb-3 text-sm font-medium text-muted-foreground">Connections</h2>
        <ul class="space-y-2">
          {connections.map((conn) => {
            const otherId = conn.from_entity === org.entity_id ? conn.to_entity : conn.from_entity
            const other = getEntityById(otherId)
            if (!other) return null
            const entityType = getEntityTypeById(otherId)
            const href = entityType === "person"
              ? `/people/${other.slug}`
              : entityType === "org"
                ? `/orgs/${other.slug}`
                : `/events/${other.slug}`
            const label = conn.from_entity === org.entity_id
              ? conn.type.replace(/-/g, " ")
              : INVERSE_LABELS[conn.type] ?? conn.type.replace(/-/g, " ")
            return (
              <li>
                <a href={href} class="text-sm font-medium hover:underline">{"name_en" in other ? other.name_en : other.name}</a>
                <div class="flex items-center gap-1 text-xs text-muted-foreground">
                  <span>{label}</span>
                  <ConfidenceBadge client:load confidence={conn.confidence} />
                </div>
              </li>
            )
          })}
        </ul>
      </div>
    )}
  </Fragment>

  <div slot="bottom">
    <h2 class="mb-3 text-sm font-medium text-muted-foreground">Network Graph</h2>
    <div class="h-[500px]">
      <GraphExplorer client:load initialEntityId={org.entity_id} />
    </div>
  </div>
</EntityLayout>
