---
import Layout from "@/layouts/main.astro"
import { ThemeToggle } from "@/components/ThemeToggle"
import { PeopleIndex } from "@/components/PeopleIndex"
import { getPeople, getConnections } from "@/lib/content"

const connections = getConnections()
const connectionCounts = new Map<string, number>()
for (const c of connections) {
  connectionCounts.set(c.from_entity, (connectionCounts.get(c.from_entity) ?? 0) + 1)
  connectionCounts.set(c.to_entity, (connectionCounts.get(c.to_entity) ?? 0) + 1)
}

const people = getPeople().map((p) => ({
  slug: p.slug,
  name_en: p.name_en,
  name_fa: p.name_fa,
  role: p.role,
  faction: p.faction,
  irgc_member: p.irgc_member,
  connectionCount: connectionCounts.get(p.entity_id) ?? 0,
}))

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "People",
  description: "People in the OIFI Databook",
  numberOfItems: people.length,
  itemListElement: people
    .sort((a, b) => a.name_en.localeCompare(b.name_en))
    .map((p, i) => ({
      "@type": "ListItem",
      position: i + 1,
      url: `https://databook.oifi.org/people/${p.slug}`,
      name: p.name_en,
    })),
}
---

<Layout title="People" description="People in the OIFI Databook" canonicalPath="/people" jsonLd={jsonLd}>
  <PeopleIndex people={people} client:load />
  <ThemeToggle client:load slot="header-actions" />
</Layout>
