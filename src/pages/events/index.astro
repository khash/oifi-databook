---
import Layout from "@/layouts/main.astro"
import { ThemeToggle } from "@/components/ThemeToggle"
import { EventsIndex } from "@/components/EventsIndex"
import { getEvents, getConnections } from "@/lib/content"

const connections = getConnections()
const connectionCounts = new Map<string, number>()
for (const c of connections) {
  connectionCounts.set(c.from_entity, (connectionCounts.get(c.from_entity) ?? 0) + 1)
  connectionCounts.set(c.to_entity, (connectionCounts.get(c.to_entity) ?? 0) + 1)
}

const events = getEvents().map((e) => ({
  slug: e.slug,
  name: e.name,
  date: e.date,
  type: e.type,
  connectionCount: connectionCounts.get(e.entity_id) ?? 0,
}))

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Events",
  description: "Events in the OIFI Databook",
  numberOfItems: events.length,
  itemListElement: events
    .sort((a, b) => b.date.localeCompare(a.date))
    .map((e, i) => ({
      "@type": "ListItem",
      position: i + 1,
      url: `https://databook.oifi.org/events/${e.slug}`,
      name: e.name,
    })),
}
---

<Layout title="Events" description="Events in the OIFI Databook" canonicalPath="/events" jsonLd={jsonLd}>
  <EventsIndex events={events} client:load />
  <ThemeToggle client:load slot="header-actions" />
</Layout>
