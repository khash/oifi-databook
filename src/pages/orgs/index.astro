---
import Layout from "@/layouts/main.astro"
import { ThemeToggle } from "@/components/ThemeToggle"
import { OrgsIndex } from "@/components/OrgsIndex"
import { getOrgs, getConnections } from "@/lib/content"

const connections = getConnections()
const connectionCounts = new Map<string, number>()
for (const c of connections) {
  connectionCounts.set(c.from_entity, (connectionCounts.get(c.from_entity) ?? 0) + 1)
  connectionCounts.set(c.to_entity, (connectionCounts.get(c.to_entity) ?? 0) + 1)
}

const orgs = getOrgs().map((o) => ({
  slug: o.slug,
  name_en: o.name_en,
  name_fa: o.name_fa,
  type: o.type,
  faction: o.faction,
  connectionCount: connectionCounts.get(o.entity_id) ?? 0,
}))

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Organisations",
  description: "Organisations in the OIFI Databook",
  numberOfItems: orgs.length,
  itemListElement: orgs
    .sort((a, b) => a.name_en.localeCompare(b.name_en))
    .map((o, i) => ({
      "@type": "ListItem",
      position: i + 1,
      url: `https://databook.oifi.org/orgs/${o.slug}`,
      name: o.name_en,
    })),
}
---

<Layout title="Organisations" description="Organisations in the OIFI Databook" canonicalPath="/orgs" jsonLd={jsonLd}>
  <OrgsIndex orgs={orgs} client:load />
  <ThemeToggle client:load slot="header-actions" />
</Layout>
