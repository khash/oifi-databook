---
import Layout from "@/layouts/main.astro"
import { Search } from "@/components/Search"
import { ThemeToggle } from "@/components/ThemeToggle"

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "OIFI Databook",
  url: "https://databook.oifi.org",
  description: "Iranian political actors, organizations and events",
  potentialAction: {
    "@type": "SearchAction",
    target: "https://databook.oifi.org/?q={search_term_string}",
    "query-input": "required name=search_term_string",
  },
}
---

<Layout jsonLd={jsonLd} canonicalPath="">
  <ThemeToggle client:load slot="header-actions" />

  <div class="flex flex-col items-center justify-center min-h-[60vh] space-y-8 py-16 text-center">
    <div class="space-y-4 max-w-2xl">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">
        Mapping Iran's Political Power Networks
      </h1>
      <p class="text-muted-foreground text-lg">
        An open-source intelligence database of political actors, organizations, and events shaping Iran's power structure.
      </p>
    </div>

    <div class="w-full max-w-lg">
      <Search client:load />
    </div>
  </div>
</Layout>
