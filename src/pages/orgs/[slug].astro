---
import EntityLayout from "@/layouts/entity.astro"
import { Badge } from "@/components/ui/badge"
import { OrgTypeBadge } from "@/components/OrgTypeBadge"
import { Separator } from "@/components/ui/separator"
import { getOrgs, getOrgById, getConnectionsForEntity, getEntityById, getEntityTypeById } from "@/lib/content"
import { GraphExplorer } from "@/components/GraphExplorer"
import { renderMarkdownWithEntities, stripMarkdown } from "@/lib/markdown"
import { getEntitySlugIndex } from "@/lib/content"
import type { Org } from "@/lib/types"
import { INVERSE_LABELS } from "@/lib/constants"
import { FactionSpectrum } from "@/components/FactionSpectrum"
import FormattedDate from "@/components/FormattedDate.astro"
import { ConnectionsList } from "@/components/ConnectionsList"
import AskChatGPT from "@/components/AskChatGPT.astro"

export function getStaticPaths() {
  return getOrgs().map((o) => ({ params: { slug: o.slug }, props: { org: o } }))
}

const { org } = Astro.props as { org: Org }
const connections = getConnectionsForEntity(org.entity_id)
const connectionItems = connections.map((conn) => {
  const otherId = conn.from_entity === org.entity_id ? conn.to_entity : conn.from_entity
  const other = getEntityById(otherId)
  if (!other) return null
  const entityType = getEntityTypeById(otherId)
  const href = entityType === "person" ? `/people/${other.slug}` : entityType === "org" ? `/orgs/${other.slug}` : `/events/${other.slug}`
  const label = conn.from_entity === org.entity_id ? conn.type.replace(/-/g, " ") : INVERSE_LABELS[conn.type] ?? conn.type.replace(/-/g, " ")
  return { type: conn.type, confidence: conn.confidence, label, otherName: "name_en" in other ? other.name_en : other.name, href, dateFrom: conn.date_from, dateTo: conn.date_to }
}).filter((x): x is NonNullable<typeof x> => x !== null)
const parentOrg = org.parent_org ? getOrgById(org.parent_org) : null
const entityIndex = getEntitySlugIndex()
const desc = stripMarkdown(org.description).slice(0, 160)

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: org.name_en,
  alternateName: org.has_native_fa_name ? org.name_fa : undefined,
  description: stripMarkdown(org.description),
  foundingDate: org.founded ? String(org.founded) : undefined,
  dissolutionDate: org.dissolved ? String(org.dissolved) : undefined,
}
---

<EntityLayout
  title={org.name_en}
  description={desc}
  ogType="website"
  canonicalPath={`/orgs/${org.slug}`}
  jsonLd={jsonLd}
  breadcrumb={{ label: "Organisations", href: "/orgs" }}
>
  <article data-pagefind-body>
    <div class="flex flex-wrap items-baseline gap-3">
      <h1 class="text-2xl font-bold" data-pagefind-meta="title">{org.name_en}</h1>
      {org.name_fa && <span class="text-lg text-muted-foreground" dir="rtl" lang="fa">{org.name_fa}</span>}
    </div>

    <div class="mt-2 flex flex-wrap items-center gap-2">
      <OrgTypeBadge type={org.type} />
      <span class="text-sm text-muted-foreground">
        {org.founded && <span>Founded <FormattedDate date={String(org.founded)} /></span>}
        {org.dissolved && <span> &middot; Dissolved <FormattedDate date={String(org.dissolved)} /></span>}
        {parentOrg && (
          <span>
            {" "}&middot; Part of{" "}
            <a href={`/orgs/${parentOrg.slug}`} class="underline hover:text-foreground">{parentOrg.name_en}</a>
          </span>
        )}
      </span>
    </div>

    {org.faction && (
      <div class="mt-2 flex flex-wrap items-center gap-2">
        <FactionSpectrum client:load faction={org.faction} />
      </div>
    )}

    <div class="mt-2 flex flex-wrap items-center gap-2">
      {org.tags.map((tag) => (
        <Badge variant="outline">{tag.replace(/-/g, " ")}</Badge>
      ))}
    </div>

    <Separator className="my-6" />

    <div class="prose prose-sm dark:prose-invert max-w-none" set:html={renderMarkdownWithEntities(org.description, entityIndex)} />

    <span data-pagefind-meta={`type:org`} class="hidden" />
    {org.faction && <span data-pagefind-meta={`faction:${org.faction}`} class="hidden" />}
    {org.has_native_fa_name && org.name_fa && <span data-pagefind-meta={`name_fa:${org.name_fa}`} class="hidden" />}
  </article>

  <div class="mt-8">
    <h2 class="mb-3 text-sm font-medium text-muted-foreground">Network Graph</h2>
    <div class="h-[500px]">
      <GraphExplorer client:load initialEntityId={org.entity_id} />
    </div>
  </div>

  <Fragment slot="sidebar">
    {connectionItems.length > 0 && (
      <ConnectionsList client:load connections={connectionItems} />
    )}

    {org.sources?.length > 0 && (
      <div>
        <h2 class="mt-8 mb-3 text-sm font-medium text-muted-foreground">Sources</h2>
        <ul class="space-y-2">
          {org.sources.map((src) => (
            <li class="text-sm">
              <a href={src.url} target="_blank" rel="noopener noreferrer" class="font-medium hover:underline">
                {src.title}
              </a>
              <span class="text-muted-foreground"> &middot; {src.publisher}{src.date && <> &middot; <FormattedDate date={src.date} /></>}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    <AskChatGPT entityName={org.name_en} entityType="org" context={org.type ? `Type: ${org.type.replace(/-/g, " ")}.` : undefined} />
  </Fragment>

</EntityLayout>
